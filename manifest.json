{
  "manifest_version": 3,
  "name": "BitShell - Binary, Hex & Base64 Converter",
  "version": "1.0.5",
  "description": "Fast binary, hex, decimal, text & Base64 converter with smart format detection, history, and one-click copy.",
  "permissions": [
    "contextMenus",
    "storage",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}